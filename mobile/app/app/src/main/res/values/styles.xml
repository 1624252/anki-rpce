<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Single fixed light theme (no DayNight/dark variant) so the app is always
         blue-on-white, matching the desktop app. -->
    <style name="Theme.RPCE" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/rpce_bg</item>
        <item name="android:statusBarColor">@color/rpce_bg</item>
        <item name="android:navigationBarColor">@color/rpce_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/rpce_accent</item>
        <item name="colorAccent">@color/rpce_accent</item>
    </style>
</resources>
